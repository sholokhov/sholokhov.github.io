# Telegram Bot
TELEGRAM_TOKEN=your-bot-token
# Your Telegram user ID (send /start to @userinfobot to find it)
TELEGRAM_ALLOWED_USER_ID=123456789

# Backblaze B2
# 1. Create a public bucket at https://www.backblaze.com/b2/cloud-storage.html
# 2. Create an application key scoped to that bucket
# 3. Note the S3 endpoint from Buckets page (e.g., s3.us-west-004.backblazeb2.com)
# 4. Public URL format: https://f004.backblazeb2.com/file/<bucket-name>
B2_KEY_ID=your-key-id
B2_APP_KEY=your-app-key
B2_BUCKET=sholokhov-photos
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
B2_PUBLIC_URL=https://f004.backblazeb2.com/file/sholokhov-photos

# GitHub
# Create a fine-grained personal access token with Contents read/write on the repo
GITHUB_TOKEN=ghp_your-token
GITHUB_REPO=sholokhov/sholokhov.github.io
